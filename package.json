{
  "name": "manager-akahu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsgo -b tsconfig.json",
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "dev": "vp run --filter website --filter server --parallel --log labeled dev",
    "dev:server": "vp run server#dev",
    "prepare": "vp config && effect-tsgo patch"
  },
  "devDependencies": {
    "@effect/language-service": "catalog:",
    "@effect/tsgo": "0.13.1",
    "@typescript/native-preview": "latest",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.5.0"
}
