{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "noEmit": true,

    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": ["src"],
  "references": [{ "path": "../../packages/domain" }, { "path": "../../packages/manager-api" }]
}
